<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="לוג שיחות"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/export_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ייצוא"
            android:layout_marginEnd="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clear_log_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="נקה"/>
    </LinearLayout>

    <!-- Stats card -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/stat_total"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:text="סהכ: 0"
                <TextView android:id="@+id/stat_answered"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="נענו: 0" android:textSize="13sp" android:textColor="#2e7d32"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <TextView android:id="@+id/stat_no_answer"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="לא נענו: 0" android:textSize="13sp" android:textColor="#c62828"/>
                <TextView android:id="@+id/stat_busy"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="תפוס: 0" android:textSize="13sp" android:textColor="#e65100"/>
            </LinearLayout>

            <LinearLayout
                android:text="סה&quot;כ: 0"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <TextView android:id="@+id/stat_avg_dur"
                    android:text="סהכ זמן: 0:00"
                    android:layout_weight="1" android:text="ממוצע: 0:00" android:textSize="13sp"/>
                <TextView android:id="@+id/stat_total_dur"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="סה\"כ זמן: 0:00" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
